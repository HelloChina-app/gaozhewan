NEXT_PUBLIC_SITE_URL=https://gaozhewan.com
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
# Optional, reserved for future transactional email.
SUBSCRIBE_FROM_EMAIL=Gaozhewan <news@gaozhewan.com>
# Optional, privacy-friendly analytics. Set to your domain to enable Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# USDT-only checkout. Configure exactly one network and its matching address.
USDT_NETWORK=
USDT_WALLET_ADDRESS=
USDT_PRICE=14

# At least 32 random characters. Never expose this value to the browser.
PRO_ACCESS_SECRET=

# Payment order notifications and receipts (Resend).
ORDER_NOTIFICATION_EMAIL=hello@gaozhewan.com
PAYMENT_FROM_EMAIL=Gaozhewan Payments <news@gaozhewan.com>
