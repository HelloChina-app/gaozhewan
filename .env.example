NEXT_PUBLIC_SITE_URL=https://gaozhewan.com
# Required in production for subscriber intake and transactional email.
RESEND_API_KEY=
# Optional sender identity after the domain is verified in Resend.
SUBSCRIBE_FROM_EMAIL=Gaozhewan <news@gaozhewan.com>
# Optional, privacy-friendly analytics. Set to your domain to enable Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# USDT-only checkout. Configure exactly one network and its matching address.
USDT_NETWORK=
USDT_WALLET_ADDRESS=
USDT_PRICE=14

# At least 32 random characters. Never expose this value to the browser.
PRO_ACCESS_SECRET=

# Private Vercel Blob store for immutable TxID usage records.
# Use this flag for OIDC-connected private stores; a legacy token also works.
USDT_ORDER_STORE=vercel-blob
BLOB_READ_WRITE_TOKEN=

# Optional: raises TronGrid rate limits. Public verification works without it.
TRONGRID_API_KEY=

# Optional fallback payment notifications and receipts (Resend).
ORDER_NOTIFICATION_EMAIL=hello@gaozhewan.com
PAYMENT_FROM_EMAIL=Gaozhewan Payments <news@gaozhewan.com>
